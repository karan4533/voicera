# ─── Voicera Frontend — Environment Variables ───────────────────────────────
#
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to git.

# Base URL for the Voicera backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for real-time live call updates
VITE_WS_URL=ws://localhost:8000/ws

# Set to "true" to use mock data instead of the real backend
# Switch to "false" once backend endpoints are ready
VITE_USE_MOCK=true

# ─── Firebase Authentication ──────────────────────────────────────────────────
# Get these values from:
#   Firebase Console → Project Settings → Your apps → SDK setup and configuration
# Never commit real values to git — use .env.local only.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
