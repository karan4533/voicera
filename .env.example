# ─── Voicera Frontend — Environment Variables ───────────────────────────────
#
# Copy this file to .env.local and fill in the real values.
# Never commit .env.local to git.

# Base URL for the Voicera backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for real-time live call updates
VITE_WS_URL=ws://localhost:8000/ws

# Set to "true" to use mock data instead of the real backend
# Switch to "false" once backend endpoints are ready
VITE_USE_MOCK=true
