rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'platform_admin' ||
        request.auth.token.email.matches('(?i)^(admin@voicera\\.ai|admin@vocera\\.ai|platform@heuristiclabs\\.ai|admin@heuristiclabs\\.ai)$')
      );
    }

    function isOrgMember(orgId) {
      return isSignedIn() && (
        request.auth.token.orgId == orgId ||
        resource.data.ownerUid == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );
    }

    match /organizations/{orgId} {
      // Signed-in users can read (admin lists all orgs; customers read own org).
      allow read: if isSignedIn();
      // MVP: any signed-in admin-console user can provision orgs.
      // Tighten to isPlatformAdmin() before production.
      allow create, update: if isSignedIn();
      allow delete: if isPlatformAdmin();
    }
  }
}
